rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    match /users/{userId} {
      allow read, write: if signedIn() && isOwner(userId);
    }

    match /vehicles/{vehicleId} {
      allow read: if signedIn() && resource.data.createdBy == request.auth.uid;
      allow create: if signedIn() && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.createdBy == request.auth.uid;
    }

    match /checklistTemplates/{templateId} {
      allow read: if signedIn() && resource.data.createdBy == request.auth.uid;
      allow create: if signedIn() && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.createdBy == request.auth.uid;
    }

    match /checks/{checkId} {
      allow read: if signedIn() && resource.data.createdBy == request.auth.uid;
      allow create: if signedIn() && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.createdBy == request.auth.uid;
    }
  }
}
